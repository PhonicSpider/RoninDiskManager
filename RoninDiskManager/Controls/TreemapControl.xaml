<UserControl x:Class="RoninDiskManager.Controls.TreemapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#080808">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Breadcrumb bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#0E0E0E"
                BorderBrush="#3A0A0A"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <DockPanel LastChildFill="True">
                <Button x:Name="BackButton"
                        DockPanel.Dock="Left"
                        Content="◀"
                        Width="26" Height="22"
                        FontSize="10"
                        Margin="0,0,6,0"
                        IsEnabled="False"
                        Click="BackButton_Click"
                        ToolTip="Navigate up one level"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Focusable="False">
                    <StackPanel x:Name="BreadcrumbPanel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── Treemap canvas ─────────────────────────────────────────────── -->
        <Canvas x:Name="TreeCanvas"
                Grid.Row="1"
                ClipToBounds="True"
                SizeChanged="TreeCanvas_SizeChanged"/>

        <!-- ── Empty state ────────────────────────────────────────────────── -->
        <TextBlock x:Name="EmptyLabel"
                   Grid.Row="1"
                   Text="Run a scan to see the treemap."
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="13"
                   Foreground="#505050"/>
    </Grid>
</UserControl>
